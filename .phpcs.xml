<?xml version="1.0"?>
<ruleset name="Wp Kses Svg Coding Standards">
    <description>WP KSES SVG coding standards — PSR-4 namespaced plugin.</description>

    <file>wp-kses-svg.php</file>
    <file>src</file>
    <exclude-pattern>vendor/</exclude-pattern>
    <exclude-pattern>tests/</exclude-pattern>
    <exclude-pattern>node_modules/</exclude-pattern>
    <exclude-pattern>lib/</exclude-pattern>

    <arg name="basepath" value="."/>
    <arg name="extensions" value="php"/>
    <arg name="parallel" value="8"/>
    <arg value="sp"/>

    <rule ref="WordPress-Extra">
        <exclude name="Universal.Files.SeparateFunctionsFromOO"/>

        <!--
            This plugin uses PSR-4 autoloading with PascalCase class filenames
            (e.g. Sanitizer.php, XmlValidator.php).  The WordPress filename
            convention (class-xml-validator.php) is incompatible with PSR-4
            Composer autoloading and is intentionally not followed here.
        -->
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
    </rule>
    <rule ref="WordPress-Docs"/>

    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="wp-kses-svg"/>
            </property>
        </properties>
    </rule>

    <rule ref="PHPCompatibilityWP"/>
    <config name="minimum_supported_wp_version" value="6.4"/>
    <config name="testVersion" value="8.1-"/>
</ruleset>
